BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgresql://user:password@host:6543/dbname
SECRET_TOKEN=your_random_secret_here
RENDER_APP_URL=https://your-app.onrender.com
ADMIN_IDS=your_admin_telegram_id_1,your_admin_telegram_id_2
ALLOWED_DOMAINS=yourdomain.com,www.yourdomain.com
GAME_ID_REGEX=^[A-Za-z0-9]{3,32}$

# ── Game Account API — WJ Safety backend ──
# Set ENABLED=true to verify Game IDs against the WJ backend before accepting submissions.
# All sensitive values (authorization, merchant, etc.) go into Render Environment Variables.
GAME_ACCOUNT_API_ENABLED=false
GAME_ACCOUNT_API_URL=https://www.wj-safety.com/tac/api/relay/get/player-search-non-bankcard
GAME_ACCOUNT_API_METHOD=GET
GAME_ACCOUNT_API_TIMEOUT_MS=8000

# WJ API query
GAME_ACCOUNT_API_MERCHANT_CODE=

# WJ API headers
GAME_ACCOUNT_API_AUTHORIZATION=
GAME_ACCOUNT_API_ENVIRONMENT=
GAME_ACCOUNT_API_LANGUAGE=zh_CN
GAME_ACCOUNT_API_PLATFORM=TCG
GAME_ACCOUNT_API_NOTPENDING=true

# WJ API optional headers (anti-403 — only sent when non-empty)
GAME_ACCOUNT_API_REFERER=https://www.wj-safety.com/311792
GAME_ACCOUNT_API_ORIGIN=https://www.wj-safety.com
GAME_ACCOUNT_API_COOKIE=
GAME_ACCOUNT_API_USER_AGENT=Mozilla/5.0
GAME_ACCOUNT_API_TAC_TRACE_ID=

# ── Platform Game Registration Check (post-submit) ──
# Used to verify Game ID registration status after player submits.
# Credentials from WJ Safety backend — DO NOT hardcode.
WJ_API_AUTHORIZATION=your_wj_authorization_here
WJ_API_COOKIE=your_wj_cookie_here
WJ_API_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120 Safari/537.36
WJ_API_REFERER=https://www.wj-safety.com/
WJ_API_ORIGIN=https://www.wj-safety.com
